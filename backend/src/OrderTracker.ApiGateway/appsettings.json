{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://jaeger:4317"
  },
  "AllowedOrigins": "http://localhost:3000,http://localhost:5000",
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "orderServiceRoute": {
        "ClusterId": "orderServiceCluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "notificationServiceRoute": {
        "ClusterId": "notificationServiceCluster",
        "Match": {
          "Path": "/hub/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "orderServiceCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://order-service:80"
          }
        }
      },
      "notificationServiceCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notification-service:80"
          }
        }
      }
    }
  }
}
